    "GetterLambdaFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "S3Bucket": "serverless-framework-deployments-us-east-1-5c37a0a3-b0e2",
          "S3Key": "serverless/mediprior/dev/1781933282222-2026-06-20T05:28:02.222Z/mediprior.zip"
        },
        "Handler": "functions/getter.handler",
        "Runtime": "python3.10",
        "FunctionName": "mediprior-dev-getter",
        "MemorySize": 1024,
        "Timeout": 10,
        "Environment": {
          "Variables": {
            "JOBS_TABLE": {
              "Ref": "JobsTable"
            },
            "PATIENTS_TABLE": {
              "Ref": "PatientsTable"
            },
            "SQS_QUEUE_URL": {
              "Ref": "MainQueue"
