      "Properties": {
        "Code": {
          "S3Bucket": "serverless-framework-deployments-us-east-1-5c37a0a3-b0e2",
          "S3Key": "serverless/mediprior/dev/1781933282222-2026-06-20T05:28:02.222Z/mediprior.zip"
